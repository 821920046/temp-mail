# ===== temp-mail 环境变量示例（纯免费额度）=====
# 复制为 worker/.dev.vars 用于本地开发，或在 Cloudflare 后台配置为 Secret。

# JWT 签名密钥（务必使用强随机值：openssl rand -hex 32）
JWT_SECRET=replace-with-strong-random-secret

# 管理后台访问密码
ADMIN_PASSWORD=change-me

# 站点访问密码（设为私人站点时启用，留空则公开）

# 支持的收件域名（逗号分隔）
MAIL_DOMAINS=example.com,mail.example.com

# 发件方式：resend | none（none 为零成本，仅收不发）
SEND_PROVIDER=none
RESEND_API_KEY=

# Telegram 推送（可选）
TELEGRAM_BOT_TOKEN=

# 附件 / 邮件保留天数（生命周期清理）
ATTACHMENT_TTL_DAYS=3
MAIL_RETENTION_DAYS=7
