{
  "name": "temp-mail",
  "version": "2.2.0",
  "private": true,
  "description": "基于 Cloudflare 纯免费额度的临时域名邮箱（Workers/D1/KV/R2/Email Routing）— 反滥用与安全加固优化版",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter worker dev",
    "build": "pnpm --filter worker build && pnpm --filter frontend build",
    "test": "pnpm --filter worker test",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "deploy": "bash scripts/deploy.sh",
    "setup": "node scripts/setup.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
